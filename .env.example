# Copy to .env and fill in the values.
# Generate SECRET_KEY:   python -c "import secrets; print(secrets.token_hex(32))"
# Generate FERNET_KEY:   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate password hash: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"

SECRET_KEY=replace-with-random-hex-string
FERNET_KEY=replace-with-fernet-key
APP_PASSWORD_HASH=replace-with-bcrypt-hash
DATA_DIR=data
PORT=8080
ACCESS_TOKEN_EXPIRE_MINUTES=60
